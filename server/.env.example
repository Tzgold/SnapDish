# Copy to .env and fill in values. Never commit .env.

PORT=4000

# Required for recipe features. Create a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

OPENAI_MODEL_PRIMARY=gpt-4o-mini
OPENAI_MODEL_FALLBACK=gpt-4o-mini
OPENAI_TIMEOUT_MS=120000

# Postgres connection string (NOT the Supabase REST URL).
# Supabase: Project Settings → Database → Connection string → URI
#   Prefer "Session pooler" or "Transaction" (host like *.pooler.supabase.com) — works on IPv4-only networks.
#   "Direct" (db.<ref>.supabase.co) is often IPv6-only; if you see getaddrinfo ENOTFOUND, switch to pooler.
# Local Postgres example:
#   DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/snapdish
DATABASE_URL=

# Set true if your host requires SSL but the URL does not include sslmode=require (Supabase URLs usually include it).
# DATABASE_SSL=true

# Random string, 32+ characters. Generate e.g. openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public URL of this API as reachable from devices (Better Auth / Expo).
# Same machine + emulator: http://10.0.2.2:4000 (Android) or http://localhost:4000 (iOS sim often works with localhost).
# Physical phone on Wi‑Fi: http://YOUR_PC_LAN_IP:4000
BETTER_AUTH_URL=http://localhost:4000
