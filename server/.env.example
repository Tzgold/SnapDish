PORT=4000

# OpenRouter (recommended for testing) — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-example_replace_with_your_key
OPENAI_MODEL_PRIMARY=openai/gpt-4o-mini
OPENAI_MODEL_FALLBACK=google/gemini-2.0-flash-001
OPENAI_TIMEOUT_MS=120000

# USDA FoodData Central — free key at https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=

# Or direct OpenAI instead (comment OPENROUTER_API_KEY and use these):
# OPENAI_API_KEY=sk-proj-example_replace_with_real_key
# OPENAI_MODEL_PRIMARY=gpt-4o-mini
# OPENAI_MODEL_FALLBACK=gpt-4o-mini

DATABASE_URL=postgresql://postgres.abcdefghij:example_db_password@aws-0-eu-north-1.pooler.supabase.com:6543/postgres?sslmode=require
BETTER_AUTH_SECRET=example_replace_with_long_random_string_at_least_40_characters

# LAN URL for email/password on your phone (ipconfig → IPv4):
BETTER_AUTH_URL=http://192.168.1.3:4000
# Public HTTPS URL for Google OAuth (ngrok). Must match EXPO_PUBLIC_AUTH_URL in app .env.
BETTER_AUTH_PUBLIC_URL=https://YOUR-SUBDOMAIN.ngrok-free.dev

# Google Cloud → APIs & Services → Credentials → OAuth 2.0 Client (Web application):
#   Authorized redirect URI: https://YOUR-SUBDOMAIN.ngrok-free.dev/api/auth/callback/google
#   Authorized JavaScript origin: https://YOUR-SUBDOMAIN.ngrok-free.dev
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
