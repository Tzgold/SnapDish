# Server (copy to server/.env)
PORT=4000

# OpenAI — recipe generation (primary + optional fallback model)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL_PRIMARY=gpt-4o-mini
OPENAI_MODEL_FALLBACK=gpt-4o-mini
# Legacy alias (optional): same as OPENAI_MODEL_PRIMARY if set
# OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=120000

# Supabase Postgres — use Session mode or direct connection string from Supabase dashboard
# Required for Better Auth + saving recipes. Use connection string with ssl if needed.
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# Optional: force SSL for pg driver when not in URL
# DATABASE_SSL=true

# Better Auth — must be the public URL of this API (same host the app uses in EXPO_PUBLIC_API_URL)
BETTER_AUTH_SECRET=generate-a-long-random-string
BETTER_AUTH_URL=http://localhost:4000

# Optional: extra trusted origins (comma-separated), e.g. production web origin
# BETTER_AUTH_TRUSTED_ORIGINS=https://app.example.com
