# Copy to .env (same folder as package.json). Restart Expo after changes.

# Physical phone: use your PC's LAN IP, NOT localhost (the phone is not your PC).
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.50:4000
# Android emulator: often http://10.0.2.2:4000
# Must match server BETTER_AUTH_URL host/port (snapdish-app/server/.env).

EXPO_PUBLIC_API_URL=http://192.168.1.50:4000
