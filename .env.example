# LAN IP — fast API for recipes, Stripe, etc. (ipconfig → IPv4 on your PC)
EXPO_PUBLIC_API_URL=http://192.168.1.3:4000

# Same as server GOOGLE_CLIENT_ID — enables Google sign-in without ngrok browser page
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_WEB_CLIENT_ID.apps.googleusercontent.com

# HTTPS ngrok URL — optional fallback for browser OAuth (same as BETTER_AUTH_PUBLIC_URL in server/.env)
# EXPO_PUBLIC_AUTH_URL=https://YOUR-SUBDOMAIN.ngrok-free.dev